{
  "displayName": "Homebridge Button Triggers",
  "name": "homebridge-button-triggers",
  "version": "1.0.0",
  "description": "Virtual Homebridge buttons and switches with local HTTP trigger routes.",
  "author": "toddcavanaugh",
  "license": "Apache-2.0",
  "homepage": "https://github.com/toddcavanaugh/homebridge-button-triggers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toddcavanaugh/homebridge-button-triggers.git"
  },
  "bugs": {
    "url": "https://github.com/toddcavanaugh/homebridge-button-triggers/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "button",
    "switch",
    "http",
    "automation",
    "stream deck"
  ],
  "pluginAlias": "ButtonTriggers",
  "pluginType": "platform",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.22.0",
    "homebridge": "^2.0.0-beta.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
